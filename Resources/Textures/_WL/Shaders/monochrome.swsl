uniform sampler2D SCREEN_TEXTURE;

const highp float ColorFactor = 1.0;

const highp float MixFactor = 0.9;
const highp vec3 MixColor = vec3(0.7, 0.4, 0.1);

//Monochrome effect
void fragment()
{
    highp vec4 color = zTextureSpec(SCREEN_TEXTURE, UV);
    highp vec3 gray = vec3(zGrayscale(color.rgb));
    highp vec3 bw_rgb = gray * ColorFactor + color.rgb * (1.0 - ColorFactor);

    bw_rgb = bw_rgb * MixFactor + MixColor * (1.0 - MixFactor);
    COLOR = vec4(bw_rgb, color.a);
}
